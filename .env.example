# Скопируй в .env. В Git коммитить только .env.example, не .env.

# --- Postgres ---
POSTGRES_DB=showcase
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong
S3_BUCKET_NAME=my-bucket

# --- Режим развёртывания ---
# prod — обычный OAuth-логин через Azure AD.
# dev  — backend поднимается без Azure-кредов; аутентификация по статичному
#        Bearer-токену (см. ниже). Фронт показывает форму ввода токена на /login.
APP_DEPLOYMENT_MODE=prod

# --- Dev-аутентификация (используется только при APP_DEPLOYMENT_MODE=dev) ---
# Секрет, который клиент шлёт в заголовке Authorization: Bearer <DEV_AUTH_TOKEN>.
DEV_AUTH_TOKEN=
# id строки из таблицы users, от имени которой будут идти запросы.
DEV_USER_ID=0

# --- OAuth: Azure AD (single-tenant) ---
# Берутся из портала Azure → App registrations → твоё приложение.
# Подробнее: DEPLOY.md → "Azure App Registration".
# В dev-режиме можно оставить пустыми.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Frontend / nginx ---
# Порт хоста (loopback!), на котором сервис `nginx` из стэка слушает HTTP.
# Перед ним host nginx + certbot терминируют HTTPS и проксируют сюда.
# Если хочется временно выставить наружу без TLS — поменяй port-mapping в
# docker-compose.yml с "127.0.0.1:${HTTP_PORT}:80" на "${HTTP_PORT}:80".
HTTP_PORT=8081

# Публичный URL сайта (как видит браузер). Нужен бэкенду для:
#  - redirect после OAuth-логина и logout,
#  - сборки absolute redirect_uri в OAuth-флоу (через X-Forwarded-*).
# В Azure App Registration redirect URI:
#   ${FRONT_URL}/login/oauth2/code/azure
# Обязательно HTTPS — иначе сессионный cookie (SameSite=None; Secure) не сядет.
FRONT_URL=https://showcase.example.com
