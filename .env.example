# Скопируйте в .env (для локального docker compose) или вставьте в Portainer → Environment variables.
# В Git коммитить только .env.example, не .env.

# --- Postgres ---
POSTGRES_DB=showcase
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong
S3_BUCKET_NAME=my-bucket

# --- OAuth: Azure AD ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- OAuth: GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Frontend ---
# Порт хоста, на котором будет торчать nginx с SPA (за reverse-proxy ставится TLS).
FRONTEND_PORT=8081
